{
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.bracketPairColorization.enabled": true,
    "editor.bracketPairColorization.independentColorPoolPerBracketType": true,
    "editor.dragAndDrop": false,
    "editor.guides.bracketPairs": true,
    "editor.mouseWheelZoom": true,
    "editor.stickyTabStops": true,
    "editor.wrappingIndent": "deepIndent",
    "editor.wordWrap": "bounded",
    "telemetry.telemetryLevel": "off",
    "github.copilot.enable": {
        "*": true,
        "yaml": true,
        "plaintext": false,
        "markdown": true
    },
    "gitlens.hovers.currentLine.over": "line",
    "gitlens.hovers.enabled": false,
    "rest-client.enableTelemetry": false,
    "editor.rulers": [
        {
            "column": 80
        },
        {
            "column": 100
        }
    ],
    "editor.inlineSuggest.enabled": true,
    "bookmarks.saveBookmarksInProject": true,
    "redhat.telemetry.enabled": false,
    "editor.fontFamily": "'FiraCode Nerd Font', 'monospace', monospace, 'Droid Sans Mono'",
    "files.autoSave": "afterDelay",
    "editor.wordWrapColumn": 120,
    "terminal.external.linuxExec": "terminator",
    "terminal.integrated.shellIntegration.enabled": true,
    "terminal.integrated.shellIntegration.history": 500,
    "terminal.integrated.defaultProfile.linux": "zsh",
    "editor.acceptSuggestionOnEnter": "off",
    "workbench.iconTheme": "vscode-icons",
    "workbench.colorTheme": "Dracula",
    "editor.fontLigatures": true,
    "editor.suggestSelection": "recentlyUsedByPrefix",
    "window.restoreWindows": "none",
    "notebook.outline.showCodeCells": true,
    "zenMode.restore": false,
    "zenMode.hideLineNumbers": false,
    "zenMode.hideStatusBar": false,
    "gitlens.codeLens.enabled": false,
    "terminal.integrated.splitCwd": "workspaceRoot",
    "terminal.integrated.tabs.showActiveTerminal": "always",
    "chat.editor.wordWrap": "on",
    "editor.minimap.renderCharacters": false,
    "gitlens.graph.minimap.additionalTypes": [
        "localBranches",
        "stashes",
        "tags",
        "remoteBranches"
    ],
    "editor.minimap.autohide": true,
    "editor.minimap.size": "fill",
    "bookmarks.useWorkaroundForFormatters": true,
    "prettier.printWidth": 79,
    "prettier.quoteProps": "consistent",
    "prettier.tabWidth": 4,
    "editor.cursorWidth": 1,
    "workbench.editor.centeredLayoutFixedWidth": true,
    "editor.minimap.maxColumn": 80,
    "window.menuBarVisibility": "toggle",
    "workbench.editor.tabSizing": "shrink",
    "window.titleBarStyle": "custom",
    "window.dialogStyle": "custom",
    "window.title": "${dirty}${activeFolderShort}${separator}${activeEditorShort}  <-  ${profileName}@${rootName}",
    "window.titleSeparator": "/",
    "window.commandCenter": true,
    "window.zoomLevel": 1,
    "editor.renderLineHighlight": "all",
    "workbench.editor.highlightModifiedTabs": true,
    "diffEditor.ignoreTrimWhitespace": false,
    "editor.suggest.matchOnWordStartOnly": false,
    "editor.suggest.preview": true,
    "editor.inlineSuggest.suppressSuggestions": true,
    "editor.suggest.showStatusBar": true,
    "editor.suggest.showIcons": true,
    "editor.suggest.snippetsPreventQuickSuggestions": true,
    "editor.suggest.insertMode": "replace",
    "terminal.integrated.shellIntegration.suggestEnabled": true,
    "editor.suggest.selectionMode": "whenTriggerCharacter",
    "editor.quickSuggestions": {
        "other": "off"
    },
    "workbench.view.alwaysShowHeaderActions": true,
    "npm.keybindingsChangedWarningShown": true,
    "[python]": {
        "python.analysis.completeFunctionParens": true,
        "jupyter.askForKernelRestart": false
    },
    "[java]": {
        "editor.defaultFormatter": "redhat.java",
        "boot-java.rewrite.reconcile": true,
        "boot-java.live-information.automatic-connection.on": false
    }
}
